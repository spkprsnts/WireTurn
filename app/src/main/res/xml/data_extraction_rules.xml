<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Зашифрованные SSH-учётные данные (пароль, ключ) -->
        <exclude domain="sharedpref" path="secure_ssh_prefs.xml"/>
        <!-- Конфиг прокси содержит VK/Yandex ссылку — не бэкапим -->
        <exclude domain="sharedpref" path="ProxyPrefs.xml"/>
        <!-- DataStore содержит SSH IP, порт, конфиг клиента -->
        <exclude domain="file" path="datastore/"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_ssh_prefs.xml"/>
        <exclude domain="sharedpref" path="ProxyPrefs.xml"/>
        <exclude domain="file" path="datastore/"/>
    </device-transfer>
</data-extraction-rules>
