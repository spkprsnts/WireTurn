<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- DataStore содержит конфиги профилей и настройки -->
        <exclude domain="file" path="datastore/"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/"/>
    </device-transfer>
</data-extraction-rules>
