<?xml version="1.0" encoding="utf-8"?>
<!-- Используется на API < 31. На API 31+ применяется data_extraction_rules.xml -->
<full-backup-content>
    <exclude domain="sharedpref" path="secure_ssh_prefs.xml"/>
    <exclude domain="sharedpref" path="ProxyPrefs.xml"/>
    <!-- DataStore содержит SSH IP, порт, конфиг клиента — не бэкапим -->
    <exclude domain="file" path="datastore/"/>
</full-backup-content>
